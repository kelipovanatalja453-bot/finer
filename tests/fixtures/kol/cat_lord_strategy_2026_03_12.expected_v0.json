    {
      "block_id": "cat_lord_2026_03_12_block_02",
      "block_type": "paragraph",
      "text": "年报很惨这个在三季报的时候大家都有预期了，这里重点说一下四季报。直接说结论：",
      "order": 1,
      "parent_block_id": "cat_lord_2026_03_12_block_01",
      "page_index": null,
      "bbox": null,
      "speaker": "猫大人FIRE",
      "start_time_sec": null,
      "end_time_sec": null,
      "quality_card": {
        "readability_score": 0.92,
        "semantic_completeness_score": 0.88,
        "financial_relevance_score": 0.9,
        "entity_resolution_score": 0.75,
        "temporal_resolution_score": 0.7,
        "evidence_traceability_score": 0.65,
        "overall_score": 0.8,
        "gate_status": "pass",
